{
  "$schema": "http://json.schemastore.org/template",
  "author": "AllSpice",
  "classifications": [
    "Web",
    "API",
    "Modular Monolith",
    "Clean Architecture",
    "CQRS"
  ],
  "identity": "AllSpice.CleanModularMonolith",
  "name": "AllSpice Clean Modular Monolith",
  "shortName": "allspice-modular",
  "sourceName": "AllSpice.CleanModularMonolith",
  "tags": {
    "language": "C#",
    "type": "solution"
  },
  "preferNameDirectory": true,
  "symbols": {
    "projectName": {
      "type": "derived",
      "valueSource": "name",
      "valueTransform": "identityForm",
      "replaces": "{{ProjectName}}",
      "description": "The project name, replacing the {{ProjectName}} token in config, email templates and the README."
    },
    "projectNameLower": {
      "type": "derived",
      "valueSource": "name",
      "valueTransform": "lowerCaseForm",
      "replaces": "{{ProjectNameLower}}",
      "description": "Lower-cased project name used for the Keycloak realm, the '-public' portal client id, and the notifications mail domain (noreply@<name>.local)."
    }
  },
  "forms": {
    "identityForm": {
      "identifier": "identity"
    },
    "lowerCaseForm": {
      "identifier": "lowerCase"
    }
  },
  "sources": [
    {
      "modifiers": [
        {
          "exclude": [
            ".git/**",
            ".serena/**",
            ".mcp.json",
            ".template.config/**",
            "**/bin/**",
            "**/obj/**",
            "CLAUDE.md",
            "TODOS.md",
            "docs/superpowers/**"
          ]
        }
      ]
    }
  ]
}
