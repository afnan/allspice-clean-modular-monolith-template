{
  "Application": {
    "Name": "API Gateway"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Sinks.File"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning",
        "Yarp": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/api-gateway-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": ["FromLogContext", "WithEnvironmentName", "WithMachineName", "WithThreadId"],
    "Properties": {
      "Application": "{{ProjectName}}.ApiGateway"
    }
  },
  "AllowedHosts": "*",
  "Performance": {
    "SlowRequestThresholdMs": 500
  },
  "ReverseProxy": {
    "_comment": "In a modular monolith, modules register FastEndpoints directly in-process, so YARP routes are OPTIONAL and Routes/Clusters are intentionally empty. The previous sample 'bff-*' routes matched /api/bff/{web,mobile}/{**catch-all} and forwarded — with the path unchanged — to the gateway's OWN service address (http://<project>-apigateway). Since no in-process endpoint serves those paths, each request re-matched the same catch-all route and self-proxied into an infinite loop, exhausting connections in any multi-instance deployment. Add routes here ONLY for a genuine downstream backend, and never point a route's cluster at the gateway on the same path the route matches.",
    "Routes": {},
    "Clusters": {}
  },
  "Keycloak": {
    "BaseUrl": "http://localhost:8080",
    "Realm": "{{ProjectNameLower}}",
    "Portals": {
      "Erp": {
        "Authority": "",
        "ClientId": ""
      },
      "MainWebsite": {
        "Authority": "",
        "ClientId": ""
      }
    }
  },
  "Identity": {
    "Sync": {
      "CronExpression": "0 0/15 * * * ?",
      "PageSize": 100,
      "MaxSuccessAge": "00:30:00"
    }
  }
}

